<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:dcterms="http://purl.org/dc/terms/"
         xmlns:prov="http://www.w3.org/ns/prov#"
         xmlns:sbol="http://sbols.org/v2#">

  <!-- ============================================================
       Genetic Inverter (NOT gate) in SBOL v2
       ============================================================
       Circuit: Input protein (LacI) represses output promoter (pLac),
       which drives expression of GFP.

       Topology:
         [LacI] represses pLac, which drives RBS, GFP_cds, terminator to produce GFP_protein

       Kinetic model (auto-generated by BioProver):
         LacI represses GFP production via Hill repression
         GFP degrades via first-order degradation
       ============================================================ -->

  <!-- ============================================================
       Part Definitions
       ============================================================ -->

  <!-- Input protein: LacI (repressor) -->
  <sbol:ComponentDefinition rdf:about="https://example.org/cd/LacI">
    <sbol:displayId>LacI</sbol:displayId>
    <dcterms:title>LacI</dcterms:title>
    <sbol:type rdf:resource="http://www.biopax.org/release/biopax-level3.owl#Protein"/>
    <sbol:role rdf:resource="http://identifiers.org/so/SO:0000316"/>
  </sbol:ComponentDefinition>

  <!-- Promoter: pLac (repressed by LacI) -->
  <sbol:ComponentDefinition rdf:about="https://example.org/cd/pLac">
    <sbol:displayId>pLac</sbol:displayId>
    <dcterms:title>pLac</dcterms:title>
    <sbol:type rdf:resource="http://www.biopax.org/release/biopax-level3.owl#DnaRegion"/>
    <sbol:role rdf:resource="http://identifiers.org/so/SO:0000167"/>
  </sbol:ComponentDefinition>

  <!-- RBS -->
  <sbol:ComponentDefinition rdf:about="https://example.org/cd/RBS1">
    <sbol:displayId>RBS1</sbol:displayId>
    <dcterms:title>RBS1</dcterms:title>
    <sbol:type rdf:resource="http://www.biopax.org/release/biopax-level3.owl#DnaRegion"/>
    <sbol:role rdf:resource="http://identifiers.org/so/SO:0000139"/>
  </sbol:ComponentDefinition>

  <!-- CDS: GFP coding sequence -->
  <sbol:ComponentDefinition rdf:about="https://example.org/cd/GFP_cds">
    <sbol:displayId>GFP_cds</sbol:displayId>
    <dcterms:title>GFP</dcterms:title>
    <sbol:type rdf:resource="http://www.biopax.org/release/biopax-level3.owl#DnaRegion"/>
    <sbol:role rdf:resource="http://identifiers.org/so/SO:0000316"/>
  </sbol:ComponentDefinition>

  <!-- Terminator -->
  <sbol:ComponentDefinition rdf:about="https://example.org/cd/terminator1">
    <sbol:displayId>terminator1</sbol:displayId>
    <dcterms:title>terminator1</dcterms:title>
    <sbol:type rdf:resource="http://www.biopax.org/release/biopax-level3.owl#DnaRegion"/>
    <sbol:role rdf:resource="http://identifiers.org/so/SO:0000141"/>
  </sbol:ComponentDefinition>

  <!-- ============================================================
       Module Definition: Inverter circuit behavior
       ============================================================ -->

  <sbol:ModuleDefinition rdf:about="https://example.org/md/inverter">
    <sbol:displayId>inverter</sbol:displayId>
    <dcterms:title>Genetic Inverter (NOT Gate)</dcterms:title>

    <!-- FunctionalComponents (instances of parts in the module) -->
    <sbol:functionalComponent>
      <sbol:FunctionalComponent rdf:about="https://example.org/md/inverter/fc/LacI">
        <sbol:displayId>LacI_fc</sbol:displayId>
        <sbol:definition rdf:resource="https://example.org/cd/LacI"/>
        <sbol:direction rdf:resource="http://sbols.org/v2#in"/>
        <sbol:access rdf:resource="http://sbols.org/v2#public"/>
      </sbol:FunctionalComponent>
    </sbol:functionalComponent>

    <sbol:functionalComponent>
      <sbol:FunctionalComponent rdf:about="https://example.org/md/inverter/fc/GFP">
        <sbol:displayId>GFP_fc</sbol:displayId>
        <sbol:definition rdf:resource="https://example.org/cd/GFP_cds"/>
        <sbol:direction rdf:resource="http://sbols.org/v2#out"/>
        <sbol:access rdf:resource="http://sbols.org/v2#public"/>
      </sbol:FunctionalComponent>
    </sbol:functionalComponent>

    <!-- Interaction: LacI inhibits GFP production -->
    <sbol:interaction>
      <sbol:Interaction rdf:about="https://example.org/md/inverter/int/repression">
        <sbol:displayId>repression</sbol:displayId>
        <sbol:type rdf:resource="http://identifiers.org/biomodels.sbo/SBO:0000169"/>

        <sbol:participation>
          <sbol:Participation rdf:about="https://example.org/md/inverter/int/repression/p/inhibitor">
            <sbol:role rdf:resource="http://identifiers.org/biomodels.sbo/SBO:0000020"/>
            <sbol:participant rdf:resource="https://example.org/cd/LacI"/>
          </sbol:Participation>
        </sbol:participation>

        <sbol:participation>
          <sbol:Participation rdf:about="https://example.org/md/inverter/int/repression/p/product">
            <sbol:role rdf:resource="http://identifiers.org/biomodels.sbo/SBO:0000011"/>
            <sbol:participant rdf:resource="https://example.org/cd/GFP_cds"/>
          </sbol:Participation>
        </sbol:participation>

      </sbol:Interaction>
    </sbol:interaction>

  </sbol:ModuleDefinition>

</rdf:RDF>
